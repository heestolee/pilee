{
  "name": "pilee",
  "version": "0.1.141",
  "description": "Personal pi coding agent config 🔥",
  "private": true,
  "type": "module",
  "pi": {
    "extensions": [
      "extensions",
      "!extensions/claude-code-ui/**"
    ],
    "skills": [
      "skills"
    ],
    "prompts": [
      "prompts"
    ],
    "themes": [
      "themes"
    ]
  },
  "scripts": {
    "sync-agents": "node scripts/sync-agents.mjs",
    "postinstall": "node scripts/sync-agents.mjs",
    "knowledge": "node scripts/knowledge.mjs",
    "knowledge:validate": "node scripts/knowledge.mjs --validate",
    "knowledge:graph": "node scripts/knowledge.mjs --graph",
    "knowledge:freshness": "node scripts/knowledge.mjs --freshness",
    "tft:regression-audit": "node scripts/tft-regression-audit.mjs",
    "knowledge:review": "node scripts/knowledge.mjs --review-candidates",
    "knowledge:resolve": "node scripts/knowledge.mjs --resolve-stale",
    "knowledge:resolver-log": "node scripts/knowledge.mjs --resolver-log",
    "test:pilee-final-check": "node scripts/check-pilee-final-check.mjs",
    "test:companion-window": "node scripts/run-typescript-test.mjs extensions/utils/companion-window.test.ts",
    "test:companion-shortcut": "node scripts/run-typescript-test.mjs extensions/frame-studio/companion-shortcut.test.ts",
    "test:tft-studio": "node scripts/run-typescript-test.mjs extensions/frame-studio/question-display.test.ts extensions/frame-studio/companion-shortcut.test.ts extensions/utils/companion-window.test.ts",
    "test:idle-screensaver": "node scripts/run-typescript-test.mjs extensions/idle-screensaver/render.test.ts extensions/idle-screensaver/task-source.test.ts",
    "test:tasks": "node scripts/run-typescript-test.mjs extensions/tasks/index.test.ts",
    "test:worktree": "node scripts/run-typescript-test.mjs extensions/worktree/shortcut.test.ts extensions/worktree/tool-fallback.test.ts",
    "test:shortcut-atlas": "node scripts/run-typescript-test.mjs extensions/shortcut-atlas/registry.test.ts extensions/shortcut-atlas/index.test.ts"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.70.0",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@mariozechner/pi-tui": "^0.70.6",
    "@modelcontextprotocol/sdk": "^1.25.0",
    "@mozilla/readability": "^0.5.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "diff": "^9.0.0",
    "elkjs": "^0.11.1",
    "file-type": "^22.0.1",
    "glimpseui": "^0.8.0",
    "linkedom": "^0.16.11",
    "node-pty": "^1.1.0",
    "pngjs": "^7.0.0",
    "turndown": "^7.2.2",
    "typebox": "^1.1.37",
    "yaml": "^2.7.0"
  }
}
