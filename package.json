    "@xterm/headless": "^6.0.0",
    "diff": "^9.0.0",
    "elkjs": "^0.11.1",
    "file-type": "^22.0.1",
    "glimpseui": "^0.8.0",
    "linkedom": "^0.16.11",
    "node-pty": "^1.1.0",
